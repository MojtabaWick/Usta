@page
@using Usta.Presentation.RazorPages.Areas.Account.Pages
@model ProfileModel
@{
    ViewData["Title"] = "پروفایل کاربر";

    // حرف اول امن برای آواتار
    char GetInitial(string? str)
        => string.IsNullOrWhiteSpace(str) ? 'م' : char.ToUpper(str.Trim()[0]);
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- هدر با آواتار -->
                <div class="position-relative">
                    <div class="bg-primary bg-gradient" style="height: 180px;"></div>

                    <div class="position-absolute start-50 translate-middle-x" style="bottom: -60px;">
                        <div class="avatar-wrapper border border-5 border-white rounded-circle overflow-hidden shadow"
                             style="width: 140px; height: 140px;">
                            @if (!string.IsNullOrEmpty(Model.User.ImageUrl))
                            {
                                <img src="@Model.User.ImageUrl" alt="عکس پروفایل" class="w-100 h-100 object-fit-cover" />
                            }
                            else
                            {
                                <div class="bg-secondary d-flex align-items-center justify-content-center w-100 h-100 text-white fs-2 fw-bold">
                                    @GetInitial(Model.User.FirstName)@GetInitial(Model.User.LastName)
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- بدنه کارت -->
                <div class="card-body pt-5 mt-4 text-center">
                    <!-- نام کامل -->
                    <h3 class="mb-1">
                        @if (string.IsNullOrWhiteSpace(Model.User.FirstName) && string.IsNullOrWhiteSpace(Model.User.LastName))
                        {
                            <span class="text-muted">نام کاربر وارد نشده</span>
                        }
                        else
                        {
                            @if (string.IsNullOrWhiteSpace(Model.User.FirstName))
                            {
                                <span class="text-muted">نام وارد نشده</span>
                            }
                            else
                            {
                                @Model.User.FirstName.Trim()
                            }

                            <text> </text>

                            @if (string.IsNullOrWhiteSpace(Model.User.LastName))
                            {
                                <span class="text-muted">نام خانوادگی وارد نشده</span>
                            }
                            else
                            {
                                @Model.User.LastName.Trim()
                            }
                        }

                        @if (Model.User.IsActive)
                        {
                            <span class="badge bg-success ms-2">فعال</span>
                        }
                        else
                        {
                            <span class="badge bg-danger ms-2">غیرفعال</span>
                        }
                    </h3>

                    <p class="text-muted mb-4">@Model.User.Email</p>

                    <!-- موجودی کیف پول -->
                    <div class="mb-5">
                        <p class="text-muted small mb-1">موجودی کیف پول</p>
                        <h2 class="text-primary fw-bold">
                            @Model.User.WalletBalance.ToString("N0") تومان
                        </h2>
                    </div>

                    <!-- اطلاعات تماس و آدرس -->
                    <div class="row g-4 text-start">
                        <!-- شماره تماس -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-telephone-forward fs-5 text-primary me-3"></i>
                                <div>
                                    <small class="text-muted">شماره تماس</small>
                                    <p class="mb-0 fw-medium">
                                        @if (string.IsNullOrWhiteSpace(Model.User.PhoneNumber))
                                        {
                                            <span class="text-muted">وارد نشده</span>
                                        }
                                        else
                                        {
                                            @Model.User.PhoneNumber
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- شهر -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt fs-5 text-primary me-3"></i>
                                <div>
                                    <small class="text-muted">شهر</small>
                                    <p class="mb-0 fw-medium">
                                        @if (string.IsNullOrWhiteSpace(Model.User.CityName))
                                        {
                                            <span class="text-muted">وارد نشده</span>
                                        }
                                        else
                                        {
                                            @Model.User.CityName.Trim()
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- آدرس -->
                        <div class="col-12">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-house-door fs-5 text-primary me-3 mt-1"></i>
                                <div>
                                    <small class="text-muted">آدرس</small>
                                    <p class="mb-0 fw-medium">
                                        @if (string.IsNullOrWhiteSpace(Model.User.Address))
                                        {
                                            <span class="text-muted">وارد نشده</span>
                                        }
                                        else
                                        {
                                            @Model.User.Address.Trim()
                                        }
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- دکمه ویرایش -->
                    <div class="mt-5">
                        <a asp-page="/Profile/Edit" asp-route-id="@Model.User.Id"
                           class="btn btn-outline-primary btn-lg px-5 rounded-pill shadow-sm">
                            <i class="bi bi-pencil-square me-2"></i>
                            ویرایش پروفایل
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}