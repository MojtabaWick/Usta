@page
@model Usta.Presentation.RazorPages.Areas.Account.Pages.RegisterModel
@{
    ViewData["Title"] = "ثبت‌نام کاربر";
}
<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4" style="max-width: 400px; width: 100%; border-radius: 1rem;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">ثبت‌نام کاربر</h2>
            <p class="text-muted">اطلاعات خود را وارد کنید</p>
        </div>
        <form method="post">
            <div class="mb-3 text-end">
                <label asp-for="Input.Email" class="form-label">ایمیل</label>
                <input asp-for="Input.Email"
                       class="form-control text-end"
                       type="email"
                       placeholder="مثال: example@email.com"
                       required />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3 text-end">
                <label asp-for="Input.Password" class="form-label">رمز عبور</label>
                <input asp-for="Input.Password"
                       type="password"
                       class="form-control text-end"
                       placeholder="••••••••"
                       required />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="mb-3 text-end">
                <label asp-for="Input.ConfirmPassword" class="form-label">تکرار رمز عبور</label>
                <input asp-for="Input.ConfirmPassword"
                       type="password"
                       class="form-control text-end"
                       placeholder="••••••••"
                       required />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <div class="mb-3 text-end">
                <label asp-for="Input.Role" class="form-label">نوع حساب</label>
                <select asp-for="Input.Role" class="form-select text-end" required>
                    <option value="" disabled selected>انتخاب کنید</option>
                    <option value="Customer">مشتری</option>
                    <option value="Expert">متخصص</option>
                </select>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-2">
                ثبت‌نام
            </button>
            <a asp-page="Login" class="btn btn-outline-secondary w-100 py-2 fw-bold">
                ورود به حساب
            </a>
        </form>
    </div>
</div>