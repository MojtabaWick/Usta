@page
@model Usta.Presentation.RazorPages.Areas.Account.Pages.LoginModel
@{
    ViewData["Title"] = "ورود به حساب کاربری";
}
<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4" style="max-width: 400px; width: 100%; border-radius: 1rem;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">ورود به حساب کاربری</h2>
            <p class="text-muted">نام کاربری و رمز عبور خود را وارد کنید</p>
        </div>
        <form method="post">
            <div class="mb-3 text-end">
                <label asp-for="Username" class="form-label">نام کاربری</label>
                <input asp-for="Username"
                       class="form-control text-end"
                       placeholder="مثال: username"
                       required />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3 text-end">
                <label asp-for="Password" class="form-label">رمز عبور</label>
                <input asp-for="Password"
                       type="password"
                       class="form-control text-end"
                       placeholder="••••••••"
                       required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-2">
                ورود
            </button>
            <a asp-area="Account" asp-page="/Register" class="btn btn-outline-secondary w-100 py-2 fw-bold">
                ثبت نام
            </a>
        </form>
        <div class="text-center mt-3">
            <a href="#" class="text-decoration-none">رمز عبور خود را فراموش کرده‌اید؟</a>
        </div>
    </div>
</div>
}