@page "{id:int}"
@using Usta.Presentation.RazorPages.Areas.Admin.Pages.Categories
@model EditModel

@{
    ViewData["Title"] = "Edit Category";
}

<h2 class="mb-4">ویرایش دسته بندی</h2>

<form method="post" enctype="multipart/form-data">

    <!-- Hidden fields -->
    <input type="hidden" asp-for="Category.Id" />
    <input type="hidden" asp-for="Category.ImagedUrl" />

    <div class="form-group mb-3">
        <label asp-for="Category.Title" class="form-label"></label>
        <input asp-for="Category.Title" class="form-control" />
        <span asp-validation-for="Category.Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Category.Description" class="form-label"></label>
        <textarea asp-for="Category.Description"
                  class="form-control"
                  rows="4"></textarea>
        <span asp-validation-for="Category.Description" class="text-danger"></span>
    </div>

    <!-- Current Image -->
    <div class="mb-3">
        <label class="form-label">تصویر فعلی</label><br />
        <img src="@Model.Category.ImagedUrl"
             alt="Category Image"
             style="max-width: 200px; border-radius: 8px"
             class="border" />
    </div>

    <!-- Upload New Image -->
    <div class="form-group mb-3">
        <label asp-for="Category.ImageFile" class="form-label">
            انتخاب تصویر جدید (اختیاری)
        </label>
        <input asp-for="Category.ImageFile"
               type="file"
               class="form-control"
               accept="image/*"
               onchange="previewImage(event)" />
        <span asp-validation-for="Category.ImageFile" class="text-danger"></span>
    </div>

    <!-- Preview New Image -->
    <div class="mb-3">
        <img id="imagePreview"
             style="max-width: 200px; display: none; border-radius: 8px"
             class="border" />
    </div>

    <button type="submit" class="btn btn-success">ذخیره تغییرات</button>
    <a asp-page="Index" class="btn btn-secondary">انصراف</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewImage(event) {
            const img = document.getElementById('imagePreview');
            img.src = URL.createObjectURL(event.target.files[0]);
            img.style.display = 'block';
        }
    </script>
}
