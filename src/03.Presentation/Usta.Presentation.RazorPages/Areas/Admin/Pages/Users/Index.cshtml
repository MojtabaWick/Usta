@page
@using Usta.Domain.Core.UserAgg.Enums
@model Usta.Presentation.RazorPages.Areas.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "مدیریت کاربران";
}

<h2 class="mb-4">لیست کاربران</h2>

<!-- سرچ -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex align-items-center gap-2">

        <input type="text"
               name="Search"
               value="@Model.Search"
               class="form-control"
               placeholder="جستجو..." />

        <select name="UserType" class="form-select">
            <option value="">همه کاربران</option>
            <option value="Expert" selected="@(Model.UserType == UserType.Expert)">
                کارشناس
            </option>
            <option value="Customer" selected="@(Model.UserType == UserType.Customer)">
                مشتری
            </option>
            <option value="Admin" selected="@(Model.UserType == UserType.Admin)">
                ادمین
            </option>
        </select>

        <button type="submit" class="btn btn-primary">
            🔍
        </button>
    </form>
    
    <a asp-page="Create" class="btn btn-success">
        ➕ ایجاد کاربر جدید
    </a>
</div>

<!-- جدول کاربران -->
<table class="table table-bordered table-hover align-middle text-center">
    <thead class="table-dark">
        <tr>
            <th>شناسه</th>
            <th>نوع کاربر</th>
            <th>تصویر</th>
            <th>نام</th>
            <th>نام خانوادگی</th>
            <th>ایمیل</th>
            <th>شماره تماس</th>
            <th>شهر</th>
            <th>کیف پول</th>
            <th>وضعیت</th>
            <th>عملیات</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Users.Items.Any())
        {
            foreach (var user in Model.Users.Items)
            {
                <tr>
                    <td>@user.Id</td>
                    
                    <td>@switch (user.UserType)
                        {
                            case "Admin":
                                <span>ادمین</span>
                                break;
                            case "Expert":
                                <span>کارشناس</span>
                                break;
                            case "Customer":
                                <span>مشتری</span>
                                break;
                            case "User":
                                <span>کاربر</span>
                                break;
                        } </td>

                    <td>
                        @if (!string.IsNullOrEmpty(user.ImageUrl))
                        {
                            <img src="@user.ImageUrl" width="50" class="rounded-circle" />
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <td>@(user.FirstName ?? "—")</td>
                    <td>@(user.LastName ?? "—")</td>
                    <td>@(user.Email)</td>
                    <td>@(user.PhoneNumber ?? "—")</td>
                    <td>@(user.CityName ?? "—")</td>

                    <td>
                        @user.WalletBalance.ToString("N0") تومان
                    </td>

                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">فعال</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">غیرفعال</span>
                        }
                    </td>

                    <td>
                        <a asp-page="Edit"
                           asp-route-id="@user.Id"
                           class="btn btn-sm btn-warning">
                            ✏ ویرایش
                        </a>
                        <form method="post"
                              asp-page-handler="Delete"
                              asp-route-id="@user.Id"
                              style="display:inline;">
                            <button type="submit"
                                    class="btn btn-sm btn-danger"
                                    onclick="return confirm('آیا از حذف این سرویس مطمئن هستید؟');">
                                🗑 حذف
                            </button>
                        </form>
                        
                        <a asp-page="ChangePassword"
                           asp-route-id="@user.Id"
                           class="btn btn-outline-warning mt-2">
                            <i class="bi bi-shield-lock me-2"></i>
                            تغییر رمز عبور
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="10">کاربری یافت نشد</td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
@if (Model.Users.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">

            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-route-PageNumber="@(Model.PageNumber - 1)"
                   asp-route-Search="@Model.Search">
                    قبلی
                </a>
            </li>

            @for (int i = 1; i <= Model.Users.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-route-PageNumber="@i"
                       asp-route-Search="@Model.Search">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.PageNumber == Model.Users.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-route-PageNumber="@(Model.PageNumber + 1)"
                   asp-route-Search="@Model.Search">
                    بعدی
                </a>
            </li>

        </ul>
    </nav>
}
