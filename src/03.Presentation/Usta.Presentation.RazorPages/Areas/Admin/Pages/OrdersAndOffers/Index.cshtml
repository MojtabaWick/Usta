@page
@model Usta.Presentation.RazorPages.Areas.Admin.Pages.OrdersAndOffers.IndexModel
@using Usta.Framework

<h2 class="mb-4">سفارش‌ها</h2>

<form method="get" class="mb-3">
    <input type="hidden" name="PageNumber" value="1" />
    <div class="input-group">
        <input type="text"
               name="Search"
               value="@Model.Search"
               class="form-control"
               placeholder="جستجو..." />
        <button class="btn btn-outline-secondary">جستجو</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
    <tr>
        <th>شناسه</th>
        <th>نام مشتری</th>
        <th>توضیح</th>
        <th>تاریخ شروع</th>
        <th>تاریخ پایان</th>
        <th>وضعیت</th>
        <th>تعداد پیشنهاد</th>
        <th>عملیات</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var order in Model.Orders.Items)
    {
        <tr>
            <td>@order.Id</td>
            <td>@order.CustomerFullName</td>
            <td>@order.Description</td>
            <td>@order.StartShamsiDate</td>
            <td>@order.EndShamsiDate</td>
            <td>
                <span class="text-black">
                    @order.Status.ToDisplayString()
                </span>
            </td>
            <td>@order.OffersCount</td>
            <td>
                <button type="button"
                        class="btn btn-sm btn-primary"
                        onclick="toggleOffers(@order.Id)">
                    مشاهده پیشنهادات
                </button>
            </td>
        </tr>

        <tr id="offers-row-@order.Id" class="d-none bg-light">
            <td colspan="5">
                <div id="offers-content-@order.Id">
                    <span class="text-muted">در حال بارگذاری...</span>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

@{
    var totalPages = (int)Math.Ceiling(
        Model.Orders.TotalCount / (double)Model.Orders.PageSize);
}

<nav>
    <ul class="pagination justify-content-center">

        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == Model.Orders.PageNumber ? "active" : "")">
                <a class="page-link"
                   href="?PageNumber=@i&Search=@Model.Search">
                    @i
                </a>
            </li>
        }

    </ul>
</nav>

@section Scripts
{
    <script>
        function toggleOffers(orderId) {
            const row = document.getElementById(`offers-row-${orderId}`);
            const content = document.getElementById(`offers-content-${orderId}`);

            // toggle
            if (!row.classList.contains("d-none")) {
                row.classList.add("d-none");
                return;
            }

            row.classList.remove("d-none");

            // جلوگیری از درخواست دوباره
            if (content.dataset.loaded) return;

            fetch(`?handler=Offers&orderId=${orderId}`)
                .then(res => res.json())
                .then(data => {

                    if (data.length === 0) {
                        content.innerHTML =
                            "<div class='text-warning'>پیشنهادی ثبت نشده است</div>";
                        return;
                    }

                    let html = `
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th>کارشناس</th>
                                    <th>قیمت</th>
                                    <th>توضیح</th>
                                    <th>وضعیت</th>
                                </tr>
                            </thead>
                            <tbody>`;

                    data.forEach(o => {
                        html += `
                            <tr>
                                <td>${o.expertName}</td>
                                <td>${o.price}</td>
                                <td>${o.description}</td>
                                <td>
                                    ${o.isAccepted
                                        ? "<span class='badge bg-success'>پذیرفته</span>"
                                        : "<span class='badge bg-secondary'>در انتظار</span>"}
                                </td>
                            </tr>`;
                    });

                    html += "</tbody></table>";

                    content.innerHTML = html;
                    content.dataset.loaded = "true";
                });
        }
    </script>
}
