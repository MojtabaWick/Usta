@page
@model Usta.Presentation.RazorPages.Areas.Customer.Pages.OrdersAndOffers.IndexModel
@using Usta.Domain.Core.OrderAgg.Enums

@{
    ViewData["Title"] = "سفارشات و پیشنهادات من";
}

<div class="container py-5" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">سفارشات من</h2>
        <a asp-page="Create" class="btn btn-success">سفارش جدید</a>
    </div>

    <!-- جستجو -->
    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text" asp-for="Search" class="form-control" placeholder="جستجو در عنوان خدمت یا توضیحات سفارش..." />
            <button type="submit" class="btn btn-outline-primary">جستجو</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a href="?PageNumber=1" class="btn btn-outline-danger">پاک کردن</a>
            }
        </div>
    </form>

    @if (!Model.OrdersAndOffers.Items.Any())
    {
        <div class="alert alert-info text-center">هنوز سفارشی ثبت نکرده‌اید.</div>
    }
    else
    {
        @foreach (var order in Model.OrdersAndOffers.Items)
        {
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <div>
                        <span class="fw-bold text-muted">سفارش #</span>
                        <span class="fw-bold fs-5">@order.Id</span>
                    </div>
                    <span class="badge fs-6 px-3 py-2 @GetStatusBadgeClass(order.Status)">
                        @GetPersianStatus(order.Status)
                    </span>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h5 class="card-title">@order.ProvidedServiceTitle</h5>
                            <p class="text-muted">@order.Description</p>

                            <div class="d-flex gap-4 text-muted small">
                                <div>
                                    <i class="bi bi-calendar"></i>
                                    از <strong>@order.StartShamsiDate</strong>
                                </div>
                                <div>
                                    <i class="bi bi-calendar-check"></i>
                                    تا <strong>@order.EndShamsiDate</strong>
                                </div>
                            </div>
                        </div>

                        @if (order.Images?.Any() == true)
                        {
                            <div class="col-md-4">
                                <div class="d-flex gap-2 flex-wrap">
                                    @foreach (var img in order.Images.Take(3))
                                    {
                                        <img src="@img.ImageUrl" alt="تصویر سفارش" class="img-thumbnail" style="width:80px;height:80px;object-fit:cover;">
                                    }
                                    @if (order.Images.Count > 3)
                                    {
                                        <span class="text-muted small align-self-center">+@(order.Images.Count - 3)</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card-footer bg-white d-flex flex-wrap gap-2">
                    <!-- دکمه مشاهده پیشنهادات -->
                    <button class="btn btn-primary" type="button" 
                            data-bs-toggle="collapse" 
                            data-bs-target="#offers-@order.Id">
                        <i class="bi bi-list-check"></i>
                        پیشنهادات (@order.OffersCount)
                    </button>

                    <!-- دکمه انجام شد -->
                    @if (order.Status == OrderStatus.InProgress)
                    {
                        <form asp-page-handler="SetDone" method="post" class="d-inline">
                            <input type="hidden" name="orderId" value="@order.Id" />
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> انجام شد
                            </button>
                        </form>
                    }

                    <!-- دکمه پرداخت -->
                    @if (order.Status == OrderStatus.WaitingForPayment)
                    {
                        <form asp-page-handler="PayOrder" method="post" class="d-inline">
                            <input type="hidden" name="orderId" value="@order.Id" />
                            <button type="submit" class="btn btn-warning text-white">
                                <i class="bi bi-credit-card"></i> پرداخت کن
                            </button>
                        </form>
                    }
                </div>

                <!-- بخش پیشنهادات (Collapse) -->
                <div class="collapse" id="offers-@order.Id">
                    <div class="card-body border-top pt-4">
                        @if (!order.Offers.Any())
                        {
                            <p class="text-muted text-center py-3">هنوز پیشنهادی ثبت نشده است.</p>
                        }
                        else
                        {
                            @foreach (var offer in order.Offers)
                            {
                                <div class="border rounded p-3 mb-3 @(offer.IsAccepted ? "border-success bg-success bg-opacity-10" : "")">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h6 class="mb-1">@offer.ExpertName</h6>
                                            <span class="text-primary fw-bold">@offer.Price.ToString("N0") تومان</span>
                                        </div>
                                        @if (offer.IsAccepted)
                                        {
                                            <span class="badge bg-success">قبول شده</span>
                                        }
                                    </div>
                                    <p class="text-muted small mt-2">@offer.Description</p>

                                    <!-- دکمه قبول کردن پیشنهاد فقط وقتی وضعیت در انتظار قبول کردن باشه -->
                                    @if (order.Status == OrderStatus.WaitingForAcceptance && !offer.IsAccepted)
                                    {
                                        <form asp-page-handler="AcceptOffer" method="post" class="mt-2">
                                            <input type="hidden" name="orderId" value="@order.Id" />
                                            <input type="hidden" name="offerId" value="@offer.Id" />
                                            <button type="submit" class="btn btn-outline-success btn-sm">
                                                قبول کردن این پیشنهاد
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }

        <!-- پیجینیشن -->
        @if (Model.OrdersAndOffers.TotalCount > Model.OrdersAndOffers.PageSize)
        {
            var totalPages = (int)Math.Ceiling(Model.OrdersAndOffers.TotalCount / (double)Model.OrdersAndOffers.PageSize);
            <nav aria-label="Page navigation" class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" href="?PageNumber=@(Model.PageNumber-1)&Search=@Model.Search">قبلی</a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" href="?PageNumber=@i&Search=@Model.Search">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.PageNumber == totalPages ? "disabled" : "")">
                        <a class="page-link" href="?PageNumber=@(Model.PageNumber+1)&Search=@Model.Search">بعدی</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@functions {
    public string GetPersianStatus(OrderStatus status) => status switch
    {
        OrderStatus.Cancelled              => "لغو شده",
        OrderStatus.Completed              => "انجام شده",
        OrderStatus.WaitingForOffers       => "در انتظار دریافت پیشنهاد",
        OrderStatus.WaitingForAcceptance   => "در انتظار قبول کردن پیشنهاد",
        OrderStatus.InProgress             => "در حال انجام",
        OrderStatus.WaitingForPayment      => "در انتظار پرداخت",
        OrderStatus.Paid                   => "پرداخت شده",
        _ => status.ToString()
    };

    public string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Cancelled              => "bg-danger text-white",
        OrderStatus.Completed              => "bg-success text-white",
        OrderStatus.WaitingForOffers       => "bg-info text-white",
        OrderStatus.WaitingForAcceptance   => "bg-warning text-dark",
        OrderStatus.InProgress             => "bg-primary text-white",
        OrderStatus.WaitingForPayment      => "bg-secondary text-white",
        OrderStatus.Paid                   => "bg-success text-white",
        _ => "bg-light text-dark"
    };
}