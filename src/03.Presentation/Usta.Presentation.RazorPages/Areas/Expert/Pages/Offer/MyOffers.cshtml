@page
@using Usta.Domain.Core.OfferAgg.Enums
@using Usta.Framework
@model Usta.Presentation.RazorPages.Areas.Expert.Pages.Offer.MyOffersModel
@{
    ViewData["Title"] = "پیشنهادهای من";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .offer-card {
        border-radius: 15px;
        transition: 0.3s;
    }

        .offer-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .accepted-badge {
        background-color: #198754;
    }

    .pending-badge {
        background-color: #ffc107;
        color: black;
    }

    .rejected-badge {
        background-color: red;
        color: black;
    }
</style>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">📦 پیشنهادهای من</h3>
    </div>

    <!-- Search -->
    <form method="get" class="row mb-4">
        <div class="col-md-10">
            <input type="text" name="Search" value="@Model.Search"
                   class="form-control"
                   placeholder="جستجو در توضیحات..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100">جستجو</button>
        </div>
    </form>

    <!-- Offers List -->
    @if (Model.Offers.Any())
    {
        <div class="row g-4">
            @foreach (var offer in Model.Offers)
            {
                <div class="col-md-6">
                    <div class="card offer-card shadow-sm p-3">

                        <div class="d-flex justify-content-between">
                            <h5>@offer.Price.ToString("N0") تومان</h5>

                            @if (offer.IsAccepted && offer.Status == OfferStatus.Accepted)
                            {
                                <span class="badge accepted-badge">قبول شده</span>
                            }
                            @if(offer.Status == OfferStatus.WaitingForAccept)
                            {
                                <span class="badge pending-badge">در انتظار تایید</span>
                            }
                            @if(offer.Status == OfferStatus.Rejected)
                            {
                                <span class="badge rejected-badge">رد شده</span>
                            }
                        </div>

                        <p class="mt-3 text-muted">
                            @offer.Description
                        </p>

                        <div class="small text-secondary">
                            تاریخ شروع: @offer.StartDateTime.ToPersianDate()
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            پیشنهادی یافت نشد
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                        <a class="page-link"
                           asp-route-PageNumber="@i"
                           asp-route-Search="@Model.Search">
                            @i
                        </a>
                    </li>
                }

            </ul>
        </nav>
    }

</div>
